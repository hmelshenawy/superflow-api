# SuperFlow environment template
# Copy to .env and fill in real values.
# Do NOT commit the real .env file.

# Public app domain
APP_DOMAIN=suservice.example.com
CORS_ORIGINS=https://suservice.example.com,http://localhost:3000
NEXT_PUBLIC_API_URL=https://suservice.example.com/api
CUSTOMER_PORTAL_URL=https://suservice.example.com

# Local host bind ports (optional, useful for direct debugging)
API_BIND_PORT=3000
WEB_BIND_PORT=3001

# Traefik
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=mytlschallenge

# App
PORT=3000
NODE_ENV=production

# Database
DATABASE_URL=mysql://myapp_user:change-me@mariadb:3306/superflow_app

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change-me-to-a-long-random-string-2
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=superflow-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Notifications
NOTIFICATIONS_EMAIL_WEBHOOK=
NOTIFICATIONS_SMS_WEBHOOK=
NOTIFICATIONS_WHATSAPP_WEBHOOK=
NOTIFICATIONS_PUSH_WEBHOOK=

# Sentry (leave empty to disable)
SENTRY_DSN=
SENTRY_RELEASE=superflow-api@0.1.0
NEXT_PUBLIC_SENTRY_DSN=
RESEND_API_KEY=
EMAIL_FROM="PrioraFlow <onboarding@resend.dev>"
