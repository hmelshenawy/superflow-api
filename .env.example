# SuperFlow environment template
# Copy to .env and fill in real values.
# Do NOT commit the real .env file.

# Public app domain
APP_DOMAIN=prioraflow.com
APP_DOMAIN_ALT=suservice.hmelshenawy.com
CORS_ORIGINS=https://prioraflow.com,https://suservice.hmelshenawy.com,http://localhost:3000
NEXT_PUBLIC_API_URL=/api
CUSTOMER_PORTAL_URL=https://prioraflow.com

# Local host bind ports
API_BIND_PORT=3000
WEB_BIND_PORT=3001

# Traefik
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=mytlschallenge

# Database
DATABASE_URL=mysql://user:password@mariadb:3306/superflow_app

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=<generate-with-openssl-rand-base64-48>
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-48>
JWT_REFRESH_EXPIRES_IN=30d

# Redis (generate with: openssl rand -base64 32)
REDIS_PASSWORD=<generate-strong-password>

# S3 / Backblaze B2
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_REGION=us-east-005
S3_BUCKET=PrioraFlow
S3_ACCESS_KEY=<your-b2-key-id>
S3_SECRET_KEY=<your-b2-secret-key>
S3_FORCE_PATH_STYLE=true

# Notifications
NOTIFICATIONS_EMAIL_WEBHOOK=
NOTIFICATIONS_SMS_WEBHOOK=
NOTIFICATIONS_WHATSAPP_WEBHOOK=
NOTIFICATIONS_PUSH_WEBHOOK=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Sentry (leave empty to disable)
SENTRY_DSN=
SENTRY_RELEASE=superflow-api@0.1.0
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
RESEND_API_KEY=
EMAIL_FROM="PrioraFlow <no-reply@prioraflow.com>"
