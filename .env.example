# Database
DATABASE_URL="mysql://user:password@127.0.0.1:3306/superflow_app"

# JWT
JWT_SECRET="your-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-here"
JWT_REFRESH_EXPIRES_IN="30d"

# App
PORT=3000
NODE_ENV=development

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# S3 / MinIO
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=superflow-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Frontend URLs
ADVISOR_APP_URL=http://localhost:3001
CUSTOMER_PORTAL_URL=http://localhost:3002
