# SuperFlow local/development environment template
# Copy to .env and fill in real values.
# Do NOT commit the real .env file.

# Public/frontend URLs
APP_DOMAIN=localhost
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
CUSTOMER_PORTAL_URL=http://localhost:3001

# App
API_BIND_PORT=3000
WEB_BIND_PORT=3001
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=mysql://user:password@127.0.0.1:3306/superflow_app

# JWT
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 / MinIO
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=superflow-media
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_FORCE_PATH_STYLE=true

# Notifications
NOTIFICATIONS_EMAIL_WEBHOOK=
NOTIFICATIONS_SMS_WEBHOOK=
NOTIFICATIONS_WHATSAPP_WEBHOOK=
NOTIFICATIONS_PUSH_WEBHOOK=
