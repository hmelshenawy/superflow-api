  customers               customers?                @relation(fields: [customer_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_vehicles_customer")
  workshops               workshops?                @relation(fields: [workshop_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_vehicles_workshop")

  @@unique([vin, workshop_id], map: "idx_vehicles_vin_workshop")
  @@index([customer_id], map: "idx_vehicles_customer")
  @@index([plate], map: "idx_vehicles_plate")
  @@index([is_deleted], map: "idx_vehicles_is_deleted")
  @@index([workshop_id], map: "idx_vehicles_workshop")
}

model plan_features {
  id                  String    @id @db.Char(36)
  plan_id             String    @db.VarChar(60)
  feature_key         String    @db.VarChar(80)
  is_included         Boolean   @default(false)
  ceiling             Int?
  overage_unit_cents  Int       @default(0)
  created_at          DateTime? @default(now()) @db.DateTime(0)
  updated_at          DateTime? @default(now()) @db.DateTime(0)

