# Public app domain
APP_DOMAIN=suservice.example.com
CORS_ORIGINS=https://suservice.example.com,http://localhost:3000
NEXT_PUBLIC_API_URL=https://suservice.example.com/api

# Local host bind ports (optional, useful for direct debugging)
API_BIND_PORT=3000
WEB_BIND_PORT=3001

# Traefik
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=mytlschallenge

# Database
DATABASE_URL=mysql://myapp_user:asdqwe%40123@mariadb:3306/superflow_app

# JWT
JWT_SECRET=change-me-super-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-super-long-random-string-2
JWT_REFRESH_EXPIRES_IN=30d

# MinIO / S3
S3_ENDPOINT=http://host.docker.internal:9000
S3_REGION=us-east-1
S3_BUCKET=superflow-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Redis / BullMQ
REDIS_PASSWORD=

# Notification providers
NOTIFICATIONS_EMAIL_WEBHOOK=
NOTIFICATIONS_SMS_WEBHOOK=
NOTIFICATIONS_WHATSAPP_WEBHOOK=
NOTIFICATIONS_PUSH_WEBHOOK=
